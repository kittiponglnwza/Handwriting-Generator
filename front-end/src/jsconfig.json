{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vitest/globals"],   // ← เพิ่มบรรทัดนี้
    "paths": {
      "@app/*":      ["src/app/*"],
      "@engine/*":   ["src/engine/*"],
      "@features/*": ["src/features/*"],
      "@shared/*":   ["src/shared/*"],
      "@hooks/*":    ["src/hooks/*"],
      "@config/*":   ["src/config/*"],
      "@styles/*":   ["src/styles/*"],
      "@lib/*":      ["src/lib/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}